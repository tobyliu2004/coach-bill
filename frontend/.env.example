# Copy to .env for local overrides. None of these are secret; VITE_ vars ship to the
# browser by design. The app defaults VITE_API_URL to http://localhost:8000 if unset.
VITE_API_URL=http://localhost:8000

# Supabase project + publishable key (Dashboard -> Project Settings -> API Keys).
# Required for the auth pages (/login etc.); the landing page works without them.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
