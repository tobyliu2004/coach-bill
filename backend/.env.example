# Copy to .env and fill in real values. .env is gitignored — never commit it.

# Supabase Postgres connection string (Session pooler URI from the Supabase dashboard:
# Project Settings → Database → Connection string → "Session pooler").
# Format: postgresql://postgres.<ref>:<password>@<host>:5432/postgres
DATABASE_URL=

# Comma-separated list of allowed browser origins for CORS (the frontend dev server).
CORS_ORIGINS=http://localhost:5173

# Supabase project URL (Dashboard → Project Settings → General). Required — the backend
# verifies access tokens against this project's JWKS endpoint and issuer.
SUPABASE_URL=https://<project-ref>.supabase.co

# Anthropic API key (console.anthropic.com → API keys). Required — powers check-in
# extraction via claude-haiku-4-5. Keep billing on PREPAID CREDITS with auto-recharge OFF:
# that cap is the only thing bounding spend if a key leaks or a loop misbehaves.
ANTHROPIC_API_KEY=sk-ant-...
